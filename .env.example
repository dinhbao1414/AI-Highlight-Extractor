# Cấu hình cho việc trích xuất phụ đề (Whisper Transcription)
WHISPER_API_KEY=your_whisper_api_key_here
# Nếu dùng OpenAI API: https://api.openai.com/v1
# Nếu dùng Local model / Local AI Server tương thích với format OpenAI: http://localhost:11434/v1
WHISPER_BASE_URL=https://api.openai.com/v1
WHISPER_MODEL=whisper-1

# Cấu hình cho phần phân tích và sinh Highlight (LLM)
LLM_API_KEY=your_llm_api_key_here
# OpenAI Base URL or Gemini with OpenAI compatibility format:
# Dùng Gemini: https://generativelanguage.googleapis.com/v1beta/openai/
# Dùng OpenAI: https://api.openai.com/v1
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# Chọn model phù hợp (Khuyến nghị: gemini-1.5-pro, gemini-1.5-flash, hoặc gpt-4-turbo, gpt-4o)
LLM_MODEL=gemini-1.5-flash
